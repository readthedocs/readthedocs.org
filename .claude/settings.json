{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -sf --max-time 10 https://raw.githubusercontent.com/readthedocs/common/main/.github/copilot-instructions.md 2>/dev/null | jq -Rs '{hookSpecificOutput:{hookEventName:\"SessionStart\",additionalContext:.}}' 2>/dev/null || true",
            "timeout": 15,
            "statusMessage": "Loading Read the Docs agent instructions"
          }
        ]
      }
    ]
  }
}
