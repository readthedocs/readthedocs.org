    "domains/notifications/": "readthedocs/domains/templates",
    "organizations/email/": "readthedocs/organizations/templates",
    "organizations/verify_email": "readthedocs/organizations/templates",
    "invitations/email/": "readthedocs/invitations/templates",
    "subscriptions/notifications/": "readthedocs/subscriptions/templates"
  }
}
